{
  "id": "feature_list",
  "type": "SharedSlice",
  "name": "FeatureList",
  "description": "A grid of features or services with icons, titles, and descriptions",
  "variations": [
    {
      "id": "default",
      "name": "Default",
      "docURL": "...",
      "version": "initial",
      "description": "FeatureList",
      "primary": {
        "title": {
          "type": "StructuredText",
          "config": {
            "label": "Title",
            "placeholder": "Features section title...",
            "allowTargetBlank": true,
            "multi": "paragraph,heading2,heading3,strong,em"
          }
        }
      },
      "items": {
        "icon": {
          "type": "Image",
          "config": {
            "label": "Icon",
            "constraint": { "width": 64, "height": 64 },
            "thumbnails": []
          }
        },
        "title": {
          "type": "Text",
          "config": {
            "label": "Title",
            "placeholder": "Feature title..."
          }
        },
        "description": {
          "type": "StructuredText",
          "config": {
            "label": "Description",
            "placeholder": "Feature description...",
            "allowTargetBlank": true,
            "multi": "paragraph,strong,em,hyperlink"
          }
        }
      }
    }
  ]
}

{
  "id": "testimonials",
  "type": "SharedSlice",
  "name": "Testimonials",
  "description": "Client testimonials and recommendations with quotes and author information",
  "variations": [
    {
      "id": "default",
      "name": "Default",
      "docURL": "...",
      "version": "initial",
      "description": "Testimonials",
      "primary": {
        "title": {
          "type": "StructuredText",
          "config": {
            "label": "Title",
            "placeholder": "Testimonials section title...",
            "allowTargetBlank": true,
            "multi": "paragraph,heading2,heading3,strong,em"
          }
        }
      },
      "items": {
        "quote": {
          "type": "StructuredText",
          "config": {
            "label": "Quote",
            "placeholder": "The testimonial quote...",
            "allowTargetBlank": true,
            "multi": "paragraph,strong,em"
          }
        },
        "name": {
          "type": "Text",
          "config": {
            "label": "Name",
            "placeholder": "Person's name..."
          }
        },
        "title": {
          "type": "Text",
          "config": {
            "label": "Title",
            "placeholder": "Job title or role..."
          }
        },
        "company": {
          "type": "Text",
          "config": {
            "label": "Company",
            "placeholder": "Company name..."
          }
        },
        "avatar": {
          "type": "Image",
          "config": {
            "label": "Avatar",
            "constraint": { "width": 100, "height": 100 },
            "thumbnails": []
          }
        }
      }
    }
  ]
}

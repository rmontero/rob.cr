{
  "id": "timeline",
  "type": "SharedSlice",
  "name": "Timeline",
  "description": "A vertical timeline for career history, project milestones, or chronological content",
  "variations": [
    {
      "id": "default",
      "name": "Default",
      "docURL": "...",
      "version": "initial",
      "description": "Timeline",
      "primary": {
        "title": {
          "type": "StructuredText",
          "config": {
            "label": "Title",
            "placeholder": "Timeline section title...",
            "allowTargetBlank": true,
            "multi": "paragraph,heading2,heading3,strong,em"
          }
        }
      },
      "items": {
        "title": {
          "type": "Text",
          "config": {
            "label": "Title",
            "placeholder": "Position or milestone title..."
          }
        },
        "company": {
          "type": "Text",
          "config": {
            "label": "Company/Organization",
            "placeholder": "Company or organization name..."
          }
        },
        "date": {
          "type": "Text",
          "config": {
            "label": "Date",
            "placeholder": "e.g. Jan 2020 - Dec 2022"
          }
        },
        "description": {
          "type": "StructuredText",
          "config": {
            "label": "Description",
            "placeholder": "Description of role, achievements, or details...",
            "allowTargetBlank": true,
            "multi": "paragraph,strong,em,hyperlink,list-item,o-list-item"
          }
        }
      }
    }
  ]
}

{
  "id": "gallery",
  "type": "SharedSlice",
  "name": "Gallery",
  "description": "A grid gallery for showcasing images with optional captions",
  "variations": [
    {
      "id": "default",
      "name": "Default",
      "docURL": "...",
      "version": "initial",
      "description": "Gallery",
      "primary": {
        "title": {
          "type": "StructuredText",
          "config": {
            "label": "Title",
            "placeholder": "Gallery title...",
            "allowTargetBlank": true,
            "multi": "paragraph,heading2,heading3,strong,em"
          }
        }
      },
      "items": {
        "image": {
          "type": "Image",
          "config": {
            "label": "Image",
            "constraint": {},
            "thumbnails": []
          }
        },
        "caption": {
          "type": "Text",
          "config": {
            "label": "Caption",
            "placeholder": "Image caption..."
          }
        }
      }
    }
  ]
}
